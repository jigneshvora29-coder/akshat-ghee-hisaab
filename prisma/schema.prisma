// ============================================================
// Prisma Schema — Akshat Ghee Hisaab
// Database: PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// USER (Admin)
// ============================================================
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // App-level relations
  transactions  Transaction[]
  auditLogs     AuditLog[]

  @@map("users")
}



// ============================================================
// CUSTOMER
// ============================================================
model Customer {
  id             String    @id @default(cuid())
  name           String
  phone          String?
  address        String?
  village        String?
  notes          String?
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  currentBalance Decimal   @default(0) @db.Decimal(12, 2)
  isPinned       Boolean   @default(false)
  isFavorite     Boolean   @default(false)
  isDeleted      Boolean   @default(false)
  isArchived     Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions   Transaction[]

  @@index([name])
  @@index([phone])
  @@index([isDeleted])
  @@index([isArchived])
  @@map("customers")
}

// ============================================================
// ITEMS / INVENTORY
// ============================================================
model Item {
  id              String             @id @default(cuid())
  name            String             @unique
  defaultQuantity Decimal            @default(1) @db.Decimal(12, 2)
  defaultUnit     String             @default("kg") // kg, gm, l, ml, pc
  defaultPrice    Decimal            @db.Decimal(12, 2)
  isDeleted       Boolean            @default(false)
  isArchived      Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  transactionItems TransactionItem[]

  @@index([name])
  @@index([isDeleted])
  @@index([isArchived])
  @@map("items")
}

// ============================================================
// TRANSACTION
// ============================================================
enum TransactionType {
  SALE
  PAYMENT
  ADJUSTMENT
}

model Transaction {
  id              String          @id @default(cuid())
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  description     String
  notes           String?
  referenceNumber String?
  date            DateTime
  runningBalance  Decimal         @db.Decimal(12, 2)
  createdById     String?
  createdBy       User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  isDeleted       Boolean         @default(false)
  isArchived      Boolean         @default(false)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           TransactionItem[]

  @@index([customerId])
  @@index([type])
  @@index([date])
  @@index([isDeleted])
  @@index([isArchived])
  @@index([referenceNumber])
  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quantity      Decimal     @db.Decimal(12, 2)
  unit          String
  rate          Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([transactionId])
  @@index([itemId])
  @@map("transaction_items")
}

// ============================================================
// BUSINESS SETTINGS (Singleton)
// ============================================================
model BusinessSettings {
  id            String   @id @default(cuid())
  businessName  String   @default("Akshat Ghee")
  ownerName     String   @default("")
  address       String   @default("")
  phone         String   @default("")
  gstNumber     String   @default("")
  upiId         String   @default("")
  upiQrImage    String?  // base64 or URL
  logoImage     String?  // base64 or URL
  bankName      String   @default("")
  bankAccount   String   @default("")
  bankIfsc      String   @default("")
  footerMessage String   @default("Thank you for your business!")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("business_settings")
}

// ============================================================
// AUDIT LOG
// ============================================================
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity     String   // e.g. "Customer", "Transaction"
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
